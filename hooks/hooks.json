{
  "description": "LLM Wiki: セッション開始時に Wiki の所在を注入し、知識質問時に参照をリマインドする（暗黙参照）。Wiki 未初期化時は無出力。",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/wiki-context.sh session",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/wiki-context.sh prompt",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/wiki-reflect.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
